generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Link {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  originalUrl String
  createdAt   DateTime @default(now())
}
